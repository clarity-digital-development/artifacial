{
  "_comment": "Wan2.2 MoE Motion Transfer — WanVideoAnimateEmbeds replaces MimicMotion. Reference image + pose video → animated video with dual expert sampling.",

  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_2-I2V-A14B-HIGH_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "compile_args": ["10", 0]
    },
    "_meta": { "title": "Load Wan2.2 High-Noise Expert" }
  },
  "2": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_2-I2V-A14B-LOW_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "compile_args": ["10", 0]
    },
    "_meta": { "title": "Load Wan2.2 Low-Noise Expert" }
  },
  "3": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16"
    },
    "_meta": { "title": "Load Wan VAE" }
  },
  "4": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-bf16.safetensors",
      "precision": "bf16"
    },
    "_meta": { "title": "Load T5 Text Encoder" }
  },
  "5": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    },
    "_meta": { "title": "Load CLIP Vision" }
  },
  "6": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "character_reference.png"
    },
    "_meta": { "title": "Load Character Reference Image" }
  },
  "7": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "motion_reference.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    },
    "_meta": { "title": "Load Motion Reference Video (pose source)" }
  },
  "8": {
    "class_type": "WanVideoClipVisionEncode",
    "inputs": {
      "clip_vision": ["5", 0],
      "image_1": ["6", 0],
      "strength_1": 1.0,
      "strength_2": 1.0,
      "crop": "center",
      "combine_embeds": "average",
      "force_offload": true
    },
    "_meta": { "title": "CLIP Vision Encode Character" }
  },
  "9": {
    "class_type": "WanVideoAnimateEmbeds",
    "inputs": {
      "vae": ["3", 0],
      "clip_embeds": ["8", 0],
      "ref_images": ["6", 0],
      "pose_images": ["7", 0],
      "face_images": ["6", 0],
      "width": 832,
      "height": 480,
      "num_frames": 81,
      "force_offload": true,
      "frame_window_size": 77,
      "colormatch": "disabled",
      "pose_strength": 1.0,
      "face_strength": 1.0
    },
    "_meta": { "title": "Animate Embeds (reference + pose + face)" }
  },
  "10": {
    "class_type": "WanVideoTorchCompileSettings",
    "inputs": {
      "backend": "inductor",
      "fullgraph": false,
      "mode": "default",
      "dynamic": false,
      "dynamo_cache_size_limit": 64,
      "compile_transformer_blocks_only": true
    },
    "_meta": { "title": "Torch Compile Settings" }
  },
  "11": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "A person performing natural motion, cinematic quality",
      "negative_prompt": "blurry, low quality, distorted, deformed, static, watermark, text",
      "t5": ["4", 0]
    },
    "_meta": { "title": "Encode Text Prompts" }
  },
  "12": {
    "class_type": "WanVideoSLG",
    "inputs": {
      "blocks": "9",
      "start_percent": 0.1,
      "end_percent": 1.0
    },
    "_meta": { "title": "Skip Layer Guidance" }
  },
  "13": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "image_embeds": ["9", 0],
      "text_embeds": ["11", 0],
      "seed": 42,
      "steps": 24,
      "cfg": 5.0,
      "shift": 5.0,
      "force_offload": true,
      "scheduler": "euler/beta",
      "riflex_freq_index": 0,
      "slg_args": ["12", 0],
      "start_step": 0,
      "end_step": 14,
      "rope_function": "comfy"
    },
    "_meta": { "title": "Sample High-Noise Expert (Steps 0→14)" }
  },
  "14": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["2", 0],
      "image_embeds": ["9", 0],
      "text_embeds": ["11", 0],
      "seed": 42,
      "steps": 24,
      "cfg": 5.0,
      "shift": 5.0,
      "force_offload": true,
      "scheduler": "dpm++/beta",
      "riflex_freq_index": 0,
      "slg_args": ["12", 0],
      "samples": ["13", 0],
      "start_step": 14,
      "end_step": -1,
      "rope_function": "comfy"
    },
    "_meta": { "title": "Sample Low-Noise Expert (Steps 14→24)" }
  },
  "15": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["3", 0],
      "samples": ["14", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    },
    "_meta": { "title": "Decode Latent to Frames" }
  },
  "16": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["15", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "artifacial_motion",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    },
    "_meta": { "title": "Save Output Video" }
  }
}
