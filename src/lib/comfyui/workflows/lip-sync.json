{
  "_comment": "Lip sync pipeline: LatentSync 1.6 with optional DeepExtract vocal isolation. 150-frame cap at 25fps = 6 seconds max. Requires clear front-facing faces throughout clip. Clean vocal audio mandatory — DeepExtract (Demucs-based) isolates vocals from mixed audio. Peak VRAM: ~18-24 GB on A6000. Processing: ~90s for 5s clip.",

  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input_video.mp4",
      "force_rate": 25,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 150,
      "skip_first_frames": 0,
      "select_every_nth": 1
    },
    "_meta": { "title": "Load Input Video (25fps, max 150 frames = 6s)" }
  },

  "2": {
    "class_type": "LoadAudio",
    "inputs": {
      "audio_file": "input_audio.mp3"
    },
    "_meta": { "title": "Load Audio File" }
  },

  "3": {
    "class_type": "DeepExtract",
    "inputs": {
      "audio": ["2", 0],
      "model": "htdemucs_ft",
      "stem": "vocals",
      "segment": 7.8,
      "overlap": 0.25,
      "shifts": 1,
      "device": "cuda"
    },
    "_meta": { "title": "DeepExtract Vocal Isolation (Demucs-based)" }
  },

  "4": {
    "class_type": "VideoLengthAdjuster",
    "inputs": {
      "images": ["1", 0],
      "audio": ["3", 0],
      "mode": "LoopToAudio"
    },
    "_meta": { "title": "Adjust Video Length to Match Audio" }
  },

  "5": {
    "class_type": "D_LatentSyncNode",
    "inputs": {
      "images": ["4", 0],
      "audio": ["3", 0],
      "lips_expression": 1.5,
      "inference_steps": 20,
      "guidance_scale": 1.5,
      "seed": 0
    },
    "_meta": { "title": "LatentSync 1.6 Lip Sync (diffusion UNet + Whisper)" }
  },

  "6": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["5", 0],
      "audio": ["3", 0],
      "frame_rate": 25,
      "loop_count": 0,
      "filename_prefix": "artifacial_lipsync",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    },
    "_meta": { "title": "Save Lip-Synced Video (25fps with isolated vocals)" }
  }
}
