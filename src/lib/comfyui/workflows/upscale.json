{
  "_comment": "Upscale + interpolation pipeline: Interpolate FIRST at 720p (matches RIFE training distribution, 4x faster than post-upscale), then 4x upscale with NMKD-Siax, then Lanczos downscale to 1080p. RIFE v4.7 (21.3 MB) for 16→30fps. No tiling needed on A6000. Peak VRAM: ~6-10 GB.",

  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input_video.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    },
    "_meta": { "title": "Load Input Video" }
  },

  "2": {
    "class_type": "RIFE VFI",
    "inputs": {
      "ckpt_name": "rife47.pth",
      "frames": ["1", 0],
      "clear_cache_after_n_frames": 10,
      "multiplier": 2,
      "fast_mode": true,
      "ensemble": true,
      "scale_factor": 1.0,
      "dtype": "float16",
      "torch_compile": false,
      "batch_size": 4
    },
    "_meta": { "title": "RIFE v4.7 Frame Interpolation (16fps → 32fps at 720p)" }
  },

  "3": {
    "class_type": "UpscaleModelLoader",
    "inputs": {
      "model_name": "4x_NMKD-Siax_200k.pth"
    },
    "_meta": { "title": "Load NMKD-Siax 4x Upscaler" }
  },

  "4": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": {
      "upscale_model": ["3", 0],
      "image": ["2", 0]
    },
    "_meta": { "title": "4x Upscale (720p → 5120x2880)" }
  },

  "5": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["4", 0],
      "upscale_method": "lanczos",
      "width": 1920,
      "height": 1080,
      "crop": "disabled"
    },
    "_meta": { "title": "Lanczos Downscale to 1080p" }
  },

  "6": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["5", 0],
      "audio": ["1", 2],
      "frame_rate": 30,
      "loop_count": 0,
      "filename_prefix": "artifacial_upscale",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "crf": 18
    },
    "_meta": { "title": "Save Upscaled Video (30fps, H.264, CRF 18)" }
  }
}
