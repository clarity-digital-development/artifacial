    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sentry/nextjs": "^10.45.0",
    "@stripe/stripe-js": "^8.9.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.362.0",
    "posthog-node": "^5.21.2",
    "prisma": "^7.4.2",
    "react": "19.2.3",
