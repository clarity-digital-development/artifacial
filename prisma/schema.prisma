generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Required Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

model User {
  id               String      @id @default(cuid())
  name             String?
  email            String?     @unique
  emailVerified    DateTime?
  image            String?
  hashedPassword   String?
  isAdmin          Boolean     @default(false)
  createdAt        DateTime    @default(now())
  plan                  String   @default("free")
  subscriptionCredits   Int      @default(100)
  purchasedCredits      Int      @default(0)
  stripeCustomerId      String?
  isFoundingMember      Boolean  @default(false)
  foundingMemberPriceId String?
  foundingMemberPlan    String?

  accounts   Account[]
  sessions   Session[]
  characters Character[]
  projects   Project[]
}

model Character {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String?  @db.Text
  style           String
  sourceImage     String?
  referenceImages String[]
  faceEmbedding   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scenes   Scene[]
  projects Project[]
}

model Project {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String    @default("Untitled Project")
  mode          String    @default("text2video") // text2video | image2video | faceswap
  characterId   String?
  character     Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  prompt        String?   @db.Text
  enhancedPrompt String?  @db.Text
  sourceVideoUrl String?  // R2 key for uploaded source video (face swap mode)
  sourceImageUrl String?  // R2 key for uploaded source image (image2video mode)
  duration       String?  @default("5") // "5" or "10"
  aspectRatio    String?  @default("16:9")
  status        String    @default("draft")
  finalVideoUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  scenes Scene[]
  jobs   GenerationJob[]
}

model Scene {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterId      String?
  character        Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  order            Int
  prompt           String   @db.Text
  enhancedPrompt   String?  @db.Text
  duration         Int      @default(3)
  cameraPreset     String?
  status           String   @default("pending")
  videoUrl         String?
  thumbnailUrl     String?
  anchorFrameStart String?
  anchorFrameEnd   String?
  generationMeta   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GenerationJob {
  id            String    @id @default(cuid())
  userId        String
  type          String
  status        String    @default("queued")
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sceneId       String?
  characterId   String?
  externalJobId String?
  queuePosition Int?
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?   @db.Text
  meta          Json?
  createdAt     DateTime  @default(now())
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  credits     Int      @default(0)
  description String
  createdAt   DateTime @default(now())
}
