generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum AffiliateTier {
  AFFILIATE
  AGENT
}

enum AffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum PayoutMethod {
  STRIPE
  PAYPAL
}

enum CommissionType {
  DIRECT    // affiliate earned from their referral
  OVERRIDE  // agent earned from sub-affiliate's commission
}

enum CommissionStatus {
  PENDING      // within NET-30 hold
  APPROVED     // past NET-30, ready to pay out
  PAID         // included in a completed payout
  CLAWED_BACK  // refund/chargeback occurred
}

enum PayoutRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ContentMode {
  SFW
  NSFW
}

enum SubscriptionTier {
  FREE
  STARTER
  CREATOR
  PRO
  STUDIO
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  UPLOADING
  COMPLETED
  BLOCKED
  FAILED
  CANCELLED
}

enum WorkflowType {
  FACE_SWAP
  IMAGE_TO_VIDEO
  TEXT_TO_VIDEO
  TEXT_TO_IMAGE
  MOTION_TRANSFER
  TALKING_HEAD
  LIP_SYNC
  UPSCALE
  STYLE_TRANSFER
  BACKGROUND_REMOVAL
  VIRTUAL_TRY_ON
  AI_HUG
  IMAGE_EDIT
}

enum GenerationProvider {
  FAL_AI
  PIAPI
  VENICE
  SELF_HOSTED
  COMFYUI_POST_PROCESS
}

// ─── NextAuth Required Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

// ─── Application Models ───

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  hashedPassword   String?
  isAdmin          Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt @default(now())

  // Subscription & credits (two-pool system)
  subscriptionTier      SubscriptionTier @default(FREE)
  subscriptionCredits   Int              @default(1000)
  purchasedCredits      Int              @default(0)
  stripeCustomerId      String?          @unique
  stripeSubscriptionId  String?
  isFoundingMember      Boolean          @default(false)
  foundingMemberPriceId String?
  foundingMemberPlan    String?

  // Content moderation
  contentMode      ContentMode      @default(SFW)
  dateOfBirth      DateTime?
  strikeCount      Int              @default(0)
  bannedAt         DateTime?
  banReason        String?
  deletedAt        DateTime?

  // Affiliate attribution — set at signup if referred via link/code
  referredByAffiliateId String?

  accounts            Account[]
  sessions            Session[]
  characters          Character[]
  projects            Project[]
  generations         Generation[]
  creditTransactions  CreditTransaction[]
  moderationEvents    ModerationEvent[]
  affiliate           Affiliate?
}

model Character {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  description      String?  @db.Text
  style            String   @default("realistic")
  sourceImage      String?
  faceImageUrl     String?
  referenceImages  String[]
  faceEmbedding    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Moderation
  nsfwEligible     Boolean  @default(false)
  estimatedAgeLow  Int?
  estimatedAgeHigh Int?

  scenes      Scene[]
  projects    Project[]
  generations Generation[]
}

model Project {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String    @default("Untitled Project")
  mode           String    @default("text2video")
  characterId    String?
  character      Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  prompt         String?   @db.Text
  enhancedPrompt String?   @db.Text
  sourceVideoUrl String?
  sourceImageUrl String?
  duration       String?   @default("5")
  aspectRatio    String?   @default("16:9")
  status         String    @default("draft")
  finalVideoUrl  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  scenes      Scene[]
  generations Generation[]
}

model Scene {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterId      String?
  character        Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  order            Int
  prompt           String   @db.Text
  enhancedPrompt   String?  @db.Text
  duration         Int      @default(3)
  cameraPreset     String?
  status           String   @default("pending")
  videoUrl         String?
  thumbnailUrl     String?
  anchorFrameStart String?
  anchorFrameEnd   String?
  generationMeta   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  generations Generation[]
}

// ─── Generation System ───

model Generation {
  id            String           @id @default(cuid())
  userId        String
  characterId   String?
  projectId     String?
  sceneId       String?
  parentGenerationId String?
  workflowType  WorkflowType
  status        GenerationStatus @default(QUEUED)
  contentMode   ContentMode      @default(SFW)
  provider      GenerationProvider @default(FAL_AI)
  modelId       String?
  apiCost       Float?
  withAudio     Boolean          @default(false)
  inputParams   Json
  outputUrl     String?
  thumbnailUrl  String?
  errorMessage  String?
  promptId      String?
  progress      Int              @default(0)
  creditsCost   Int              @default(0)
  retryCount    Int              @default(0)
  resolution    String           @default("720p")
  durationSec   Float?
  queuedAt      DateTime         @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  generationTimeMs Int?

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  character          Character?       @relation(fields: [characterId], references: [id])
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  scene              Scene?           @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  parentGeneration   Generation?      @relation("PostProcessChain", fields: [parentGenerationId], references: [id], onDelete: SetNull)
  childGenerations   Generation[]     @relation("PostProcessChain")
  moderation         GenerationModeration?
  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([workflowType])
  @@index([parentGenerationId])
}

model GenerationModeration {
  id                    String     @id @default(cuid())
  generationId          String     @unique
  promptClassification  Json
  outputScanResult      Json?
  flagged               Boolean    @default(false)
  promptText            String?
  ipAddress             String?
  createdAt             DateTime   @default(now())

  generation            Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  credits      Int      @default(0)
  description  String
  generationId String?
  createdAt    DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model ModerationEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ─── Affiliate / Agency Program ───

model Affiliate {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  code              String          @unique  // user-chosen promo code (e.g. "SARAH")
  tier              AffiliateTier   @default(AFFILIATE)
  status            AffiliateStatus @default(PENDING)

  // Agent relationship (NULL = no parent agent)
  parentAffiliateId String?
  parentAffiliate   Affiliate?      @relation("AgentAffiliates", fields: [parentAffiliateId], references: [id])
  subAffiliates     Affiliate[]     @relation("AgentAffiliates")

  // Payout settings
  payoutMethod      PayoutMethod?
  stripeAccountId   String?         // Stripe Connect account ID
  paypalEmail       String?         // PayPal email for payouts

  // Application
  platformUrl       String?         // e.g. TikTok/Instagram link
  audienceSize      String?
  contentNiche      String?
  applicationNote   String?         @db.Text
  reviewedAt        DateTime?
  reviewedBy        String?         // admin userId

  commissions       Commission[]
  clicks            AffiliateClick[]
  payoutRequests    PayoutRequest[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([code])
  @@index([status])
  @@index([parentAffiliateId])
}

model Commission {
  id                   String           @id @default(cuid())
  affiliateId          String
  affiliate            Affiliate        @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  type                 CommissionType
  // For override commissions: which sub-affiliate generated the underlying sale
  sourceAffiliateId    String?

  // Attribution
  referredUserId       String?
  stripeInvoiceId      String           @unique
  stripeSubscriptionId String
  stripeCustomerId     String

  // Financial
  subscriptionRevenue  Float            // what the customer paid (USD)
  amount               Float            // commission earned (USD)
  currency             String           @default("usd")

  // Lifecycle — month 1–12 for affiliate DIRECT; uncapped for agent OVERRIDE
  monthNumber          Int              @default(1)
  status               CommissionStatus @default(PENDING)
  paysOutAt            DateTime         // invoice date + 30 days (NET-30)
  paidAt               DateTime?
  payoutRequestId      String?
  payoutRequest        PayoutRequest?   @relation(fields: [payoutRequestId], references: [id])

  createdAt            DateTime         @default(now())

  @@index([affiliateId])
  @@index([status])
  @@index([paysOutAt])
  @@index([stripeSubscriptionId])
}

model AffiliateClick {
  id                String    @id @default(cuid())
  affiliateId       String
  affiliate         Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  ipHash            String    // hashed for privacy
  userAgent         String?
  landingPage       String?
  convertedToUserId String?   // set when this click leads to a signup

  createdAt         DateTime  @default(now())

  @@index([affiliateId])
  @@index([createdAt])
}

model PayoutRequest {
  id          String              @id @default(cuid())
  affiliateId String
  affiliate   Affiliate           @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  amount      Float               // total USD being paid out
  method      PayoutMethod
  status      PayoutRequestStatus @default(PENDING)

  // Stripe Connect
  stripeTransferId    String?
  // PayPal Payouts
  paypalBatchId       String?
  paypalPayoutItemId  String?

  commissions Commission[]        // which commissions are included

  notes       String?
  requestedAt DateTime            @default(now())
  processedAt DateTime?

  @@index([affiliateId])
  @@index([status])
}
