generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum ContentMode {
  SFW
  NSFW
}

enum SubscriptionTier {
  FREE
  STARTER
  CREATOR
  PRO
  STUDIO
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  UPLOADING
  COMPLETED
  BLOCKED
  FAILED
  CANCELLED
}

enum WorkflowType {
  FACE_SWAP
  IMAGE_TO_VIDEO
  TEXT_TO_VIDEO
  TEXT_TO_IMAGE
  MOTION_TRANSFER
  TALKING_HEAD
  LIP_SYNC
  UPSCALE
  STYLE_TRANSFER
}

enum GenerationProvider {
  FAL_AI
  SELF_HOSTED
  COMFYUI_POST_PROCESS
}

// ─── NextAuth Required Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  hashedPassword   String?
  isAdmin          Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt @default(now())

  // Subscription & credits (two-pool system)
  subscriptionTier      SubscriptionTier @default(FREE)
  subscriptionCredits   Int              @default(100)
  purchasedCredits      Int              @default(0)
  stripeCustomerId      String?          @unique
  stripeSubscriptionId  String?
  isFoundingMember      Boolean          @default(false)
  foundingMemberPriceId String?
  foundingMemberPlan    String?

  // Content moderation
  contentMode      ContentMode      @default(SFW)
  dateOfBirth      DateTime?
  strikeCount      Int              @default(0)
  bannedAt         DateTime?
  banReason        String?
  deletedAt        DateTime?

  accounts            Account[]
  sessions            Session[]
  characters          Character[]
  projects            Project[]
  generations         Generation[]
  creditTransactions  CreditTransaction[]
  moderationEvents    ModerationEvent[]
}

model Character {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  description      String?  @db.Text
  style            String   @default("realistic")
  sourceImage      String?
  faceImageUrl     String?
  referenceImages  String[]
  faceEmbedding    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Moderation
  nsfwEligible     Boolean  @default(false)
  estimatedAgeLow  Int?
  estimatedAgeHigh Int?

  scenes      Scene[]
  projects    Project[]
  generations Generation[]
}

model Project {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String    @default("Untitled Project")
  mode           String    @default("text2video")
  characterId    String?
  character      Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  prompt         String?   @db.Text
  enhancedPrompt String?   @db.Text
  sourceVideoUrl String?
  sourceImageUrl String?
  duration       String?   @default("5")
  aspectRatio    String?   @default("16:9")
  status         String    @default("draft")
  finalVideoUrl  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  scenes      Scene[]
  generations Generation[]
}

model Scene {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterId      String?
  character        Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  order            Int
  prompt           String   @db.Text
  enhancedPrompt   String?  @db.Text
  duration         Int      @default(3)
  cameraPreset     String?
  status           String   @default("pending")
  videoUrl         String?
  thumbnailUrl     String?
  anchorFrameStart String?
  anchorFrameEnd   String?
  generationMeta   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  generations Generation[]
}

// ─── Generation System ───

model Generation {
  id            String           @id @default(cuid())
  userId        String
  characterId   String?
  projectId     String?
  sceneId       String?
  parentGenerationId String?
  workflowType  WorkflowType
  status        GenerationStatus @default(QUEUED)
  contentMode   ContentMode      @default(SFW)
  provider      GenerationProvider @default(FAL_AI)
  modelId       String?
  apiCost       Float?
  withAudio     Boolean          @default(false)
  inputParams   Json
  outputUrl     String?
  thumbnailUrl  String?
  errorMessage  String?
  promptId      String?
  progress      Int              @default(0)
  creditsCost   Int              @default(0)
  retryCount    Int              @default(0)
  resolution    String           @default("720p")
  durationSec   Float?
  queuedAt      DateTime         @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  generationTimeMs Int?

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  character          Character?       @relation(fields: [characterId], references: [id])
  project            Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  scene              Scene?           @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  parentGeneration   Generation?      @relation("PostProcessChain", fields: [parentGenerationId], references: [id], onDelete: SetNull)
  childGenerations   Generation[]     @relation("PostProcessChain")
  moderation         GenerationModeration?
  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([workflowType])
  @@index([parentGenerationId])
}

model GenerationModeration {
  id                    String     @id @default(cuid())
  generationId          String     @unique
  promptClassification  Json
  outputScanResult      Json?
  flagged               Boolean    @default(false)
  promptText            String?
  ipAddress             String?
  createdAt             DateTime   @default(now())

  generation            Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  type         String
  credits      Int      @default(0)
  description  String
  generationId String?
  createdAt    DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model ModerationEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
